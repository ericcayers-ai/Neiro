{
  "manifest_version": 2,
  "id": "vocals-neural-ensemble",
  "task": "separate",
  "stems": ["vocals", "instrumental"],
  "display_name": "Vocals reference ensemble (BS + Mel RoFormer + TTA)",
  "adapter": "neiro.adapters.ensemble_separator:EnsembleSeparator",
  "requires": ["audio_separator"],
  "params": {
    "mode": "mean",
    "tta": true,
    "members": [
      {
        "adapter": "neiro.adapters.audio_separator_adapter:AudioSeparatorModel",
        "params": {
          "model_id": "bs-roformer-1297-ens",
          "model_filename": "model_bs_roformer_ep_317_sdr_12.9755.ckpt",
          "stems": ["vocals", "instrumental"],
          "stem_labels": {"vocals": "Vocals", "instrumental": "Instrumental"},
          "quality_class": "reference",
          "license_spdx": "MIT"
        },
        "weight": 1.0
      },
      {
        "adapter": "neiro.adapters.audio_separator_adapter:AudioSeparatorModel",
        "params": {
          "model_id": "mel-roformer-inst-ens",
          "model_filename": "melband_roformer_inst_v2.ckpt",
          "stems": ["vocals", "instrumental"],
          "stem_labels": {"vocals": "Vocals", "instrumental": "Instrumental"},
          "quality_class": "reference",
          "license_spdx": "MIT"
        },
        "weight": 0.9
      }
    ]
  },
  "audio": { "sample_rate": 44100, "channels": 2 },
  "chunking": { "seconds": 30.0, "overlap": 0.5 },
  "quality_class": "reference",
  "vram": { "fp32_gb": 5.0, "fp16_gb": 3.0, "supports_fp16": true },
  "license": { "spdx": "MIT", "note": "credit UVR; verify commercial terms", "source": "https://github.com/nomadkaraoke/python-audio-separator" },
  "provenance": { "author": "neiro", "method": "BS-RoFormer + Mel-RoFormer weighted fusion with TTA" }
}
