{
  "manifest_version": 2,
  "id": "deepfilternet",
  "task": "enhance",
  "display_name": "DeepFilterNet (denoise)",
  "adapter": "neiro.adapters.restoration_adapters:DeepFilterNetDenoiser",
  "requires": ["df"],
  "params": {},
  "weights": [{"kind": "managed", "note": "checkpoint auto-downloads on first init_df() call"}],
