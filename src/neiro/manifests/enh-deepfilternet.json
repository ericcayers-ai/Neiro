  "vram": { "fp32_gb": 0.5, "supports_fp16": false },
  "license": { "spdx": "MIT", "source": "https://github.com/Rikorose/DeepFilterNet" },
  "provenance": { "author": "Rikorose", "fixes": "broadband / stationary noise" }
}
